{
    "name": "ksfraser/ksf-project-management",
    "description": "Enterprise Project Management library - composer-installable, PSR-4, DI-ready, TDD-first. Replicates/replaces PM capabilities from dotProject, OpenProject, SuiteCRM, vTiger, WebERP, Dolibarr.",
    "type": "library",
    "license": "GPL-3.0",
    "keywords": [
        "project-management",
        "pm",
        "dotproject",
        "openproject",
        "frontaccounting",
        "weberp",
        "crm",
        "ksf"
    ],
    "authors": [
        {
            "name": "KSFII Development Team",
            "email": "dev@ksfii.org"
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": ">=8.0",
        "psr/log": "^1.1",
        "psr/event-dispatcher": "^1.0",
        "psr/container": "^2.0",
        "ksfraser/exceptions": "*",
        "ksfraser/genericinterface": "*",
        "ksfraser/ksf-schemamanager": "*",
        "ksfraser/validation": "*",
        "ksfraser/file": "*",
        "doctrine/dbal": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.0",
        "squizlabs/php_codesniffer": "^3.0",
        "ksfraser/famock": "*"
    },
    "autoload": {
        "psr-4": {
            "Ksfraser\\ProjectManagement\\": "src/Ksfraser/ProjectManagement/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ksfraser\\ProjectManagement\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --colors=always",
        "test-coverage": "phpunit --coverage-html coverage",
        "test-coverage-clover": "phpunit --coverage-clover coverage.clover",
        "phpdoc": "phpdocumentor",
        "phpstan": "phpstan analyse src --level=8",
        "phpcs": "phpcs --standard=PSR12 src tests",
        "phpcbf": "phpcbf --standard=PSR12 src tests",
        "ci": [
            "@phpstan",
            "@phpcs",
            "@test"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "phpdocumentor/phpdocumentor": true
        }
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://packagist.org",
            "canonical": true
        },
        {
            "type": "vcs",
            "url": "https://github.com/ksfraser/ksf_SchemaManager"
        },
        {
            "type": "vcs",
            "url": "https://github.com/ksfraser/FILE"
        },
        {
            "type": "vcs",
            "url": "https://github.com/ksfraser/ksf_Cache"
        }
    ]
}